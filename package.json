{
  "name": "react-ecommerce",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "XDG_CONFIG_HOME=$PWD/.config next dev --webpack",
    "build": "XDG_CONFIG_HOME=$PWD/.config next build --webpack",
    "start": "XDG_CONFIG_HOME=$PWD/.config next start",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:generate:pg": "prisma generate --schema prisma/schema.postgres.prisma",
    "db:push:pg": "prisma db push --schema prisma/schema.postgres.prisma",
    "db:migrate:pg": "prisma migrate dev --schema prisma/schema.postgres.prisma",
    "db:seed:pg": "tsx prisma/seed.ts",
    "ops:pg:wait": "bash scripts/pg-wait.sh",
    "ops:pg:backup": "bash scripts/pg-backup.sh",
    "ops:pg:restore": "bash scripts/pg-restore.sh",
    "ops:check:env": "bash scripts/check-production-env.sh",
    "ops:orders:reconcile": "bash scripts/reconcile-orders.sh"
  },
  "overrides": {
    "effect": "3.20.0"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^6.2.1",
    "@tanstack/react-query": "^5.62.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "next": "^16.1.7",
    "next-auth": "^4.24.11",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.54.2",
    "sanitize-html": "^2.13.1",
    "stripe": "^20.4.1",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/sanitize-html": "^2.13.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.7",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "prisma": "^6.2.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  }
}
